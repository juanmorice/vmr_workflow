# ============================================
# VMR Scorecard Environment Configuration
# ============================================
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to Git (it contains passwords)
# ============================================

AIRFLOW_UID=50000

# Yellowbrick database credentials
YELLOWBRICK_USER=your_username
YELLOWBRICK_PASSWORD=your_password

# Excel file path (Docker path)
EXCEL_FILE_PATH=/opt/airflow/src/template_form.xlsx

# SMTP Email Configuration (Office 365)
AIRFLOW__SMTP__SMTP_HOST=smtp.office365.com
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_USER=your_email@catalina.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_email_password
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_MAIL_FROM=your_email@catalina.com
