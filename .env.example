# ================================================================
# VMR Scorecard Workflow - Environment Configuration Template
# ================================================================
# INSTRUCTIONS FOR NEW DEVELOPER:
# 1. Copy this file to .env in the project root
# 2. Update ONLY the values marked with <YOUR_VALUE> placeholders
# 3. DO NOT commit .env to Git - it contains sensitive passwords
# 4. This file will be ignored by .gitignore automatically
# ================================================================

# ==============================================
# REQUIRED: Yellowbrick Database Credentials
# ==============================================
# Update with YOUR Catalina network credentials
YELLOWBRICK_USER=<your_network_username>
YELLOWBRICK_PASSWORD=<your_yellowbrick_password>

# ==============================================
# REQUIRED: File Paths
# ==============================================
# For DOCKER (Airflow): Use /opt/airflow paths
# For STANDALONE: Use your local project path
# Examples:
#   Docker: /opt/airflow/src/template_form.xlsx
#   Windows: C:/Users/username/AIRFLOW_project/src/template_form.xlsx
#   Linux:   /home/username/AIRFLOW_project/src/template_form.xlsx
EXCEL_FILE_PATH=<your_path_to_template_form.xlsx>

# Network path to category mappings file
# IMPORTANT: Replace "moricejuan" with YOUR network username
# Example: /analytical_services/Public/yourname/Catalina_PG_Categories.xlsx
CUSTOM_BRAND_DESC_PATH=/analytical_services/Public/<your_username>/Catalina_PG_Categories.xlsx

# ==============================================
# REQUIRED: Email/SMTP Configuration (Office365)
# ==============================================
# These are used for completion notifications
AIRFLOW__SMTP__SMTP_HOST=smtp.office365.com
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_PORT=587

# Your Office365 credentials
# Tip: For Office365, use an App Password: https://support.microsoft.com/en-us/account-billing/using-app-passwords-with-2-step-verification
AIRFLOW__SMTP__SMTP_USER=<your_email@catalina.com>
AIRFLOW__SMTP__SMTP_PASSWORD=<your_office365_app_password>
AIRFLOW__SMTP__SMTP_MAIL_FROM=<your_email@catalina.com>

# ==============================================
# OPTIONAL: Docker/Airflow Settings
# ==============================================
# Airflow unique ID (change only if Docker port conflicts)
AIRFLOW_UID=50000
